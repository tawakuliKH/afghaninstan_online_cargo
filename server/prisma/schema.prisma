// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum DocumentType {
  PASSPORT
  TAZKIRA
}

model User {
  id                      String        @id @default(uuid())
  email                   String        @unique
  passwordHash            String

  legalFullName           String
  nickname                String
  dateOfBirth             DateTime
  whatsappNumber          String

  documentType            DocumentType
  documentNumber          String        @unique
  documentIssuingCountry  String?

  permanentCountry        String
  permanentCity           String
  currentCountry          String
  currentCity             String

  passportPhotoUrl        String
  facePhotoUrl            String
  visaResidencyDocUrl     String?

  accountStatus           AccountStatus @default(PENDING)
  adminNote                String?
  isAdmin                  Boolean       @default(false)

  rating                   Float         @default(0)
  reviewCount              Int           @default(0)
  packagesDeliveredCount   Int           @default(0)

  trips                    Trip[]
  packages                  Package[]
  senderDeliveries         Delivery[]    @relation("SenderDeliveries")
  travelerDeliveries       Delivery[]    @relation("TravelerDeliveries")

  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  @@map("users")
}

model Trip {
  id              String   @id @default(uuid())
  travelerId      String
  traveler        User     @relation(fields: [travelerId], references: [id])

  originCountry   String
  originCity      String
  destCountry     String
  destCity        String

  capacityWeight  Float?
  capacityNote    String?

  departureDate   DateTime
  notes           String?

  deliveries            Delivery[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("trips")
}

model Package {
  id                String   @id @default(uuid())
  senderId          String
  sender            User     @relation(fields: [senderId], references: [id])

  title             String
  weight            Float

  originCountry     String
  originCity        String
  destCountry       String
  destCity          String

  recipientName     String
  recipientWhatsapp String
  recipientEmail    String

  goodsPhotoUrl     String?
  notes             String?

  deliveries            Delivery[]

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@map("packages")
}

enum DeliveryStatus {
  PROPOSED
  ACCEPTED
  FINALIZED
  CANCELLED
}

enum PaymentLocation {
  ORIGIN
  DESTINATION
}

model Delivery {
  id                    String          @id @default(uuid())
  packageId             String
  package               Package         @relation(fields: [packageId], references: [id])
  tripId                String?
  trip                  Trip?           @relation(fields: [tripId], references: [id])
  senderId              String
  sender                User            @relation("SenderDeliveries", fields: [senderId], references: [id])
  travelerId            String
  traveler              User            @relation("TravelerDeliveries", fields: [travelerId], references: [id])

  agreedAmount          Float
  currency              String
  paymentLocation       PaymentLocation
  status                DeliveryStatus  @default(PROPOSED)
  estimatedDeliveryDate DateTime?
  finalizedAt           DateTime?
  commissionAmount      Float?
  commissionPaid        Boolean         @default(false)

  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  @@map("deliveries")
}